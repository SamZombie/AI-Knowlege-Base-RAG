# LLM Configuration
# Options: "ollama" or "openai"
LLM_BACKEND=ollama
OLLAMA_MODEL=mistral
OLLAMA_BASE_URL=http://localhost:11434

# OpenAI (only needed if LLM_BACKEND=openai)
OPENAI_API_KEY=your_openai_api_key_here

# Qdrant Vector Database
# Use 'qdrant' when running via docker compose, 'localhost' for local dev 
QDRANT_HOST=localhost
QDRANT_PORT=6333

# Embedding Model (runs locally, no API key needed)
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
VECTOR_DIMENSIONS=1024

API_HOST=localhost
API_PORT=8000

# App Settings
DOCS_PATH=docs
APP_HOST=0.0.0.0
APP_PORT=8000
TOP_K_RESULTS=10
CHUNK_SIZE=1000
CHUNK_OVERLAP=200